{
  "name": "site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev",
    "compress:zstd": "zstd -T0 -fk -16 dist/*.js || true",
    "compress:brotli": "brotli -fk dist/*.js || true",
    "preview": "rsbuild preview",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --fix",
    "format": "biome format src --write",
    "check": "biome check src",
    "check:fix": "biome check src --fix",
    "biome:upgrade": "biome migrate --write",
    "test": "rstest run",
    "test:watch": "rstest --watch",
    "ci:lint": "biome ci src",
    "ci:typecheck": "tsc --noEmit",
    "update:packageManager": "corepack use pnpm@latest"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "react-vega": "^8.0.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "vega-typings": "^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@rsbuild/core": "^2.1.2",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rstest/adapter-rsbuild": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions"
    ],
    "development": [
      "last 1 Chrome version",
      "last 1 Firefox version",
      "last 1 Safari version"
    ]
  }
}
