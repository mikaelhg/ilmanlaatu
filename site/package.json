{
  "name": "site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev",
    "compress:zstd": "zstd -T0 -fk -16 dist/*.js || true",
    "compress:brotli": "brotli -fk dist/*.js || true",
    "preview": "rsbuild preview",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --fix",
    "format": "biome format src --write",
    "check": "biome check src",
    "check:fix": "biome check src --fix",
    "biome:upgrade": "biome migrate --write",
    "test": "rstest run",
    "test:watch": "rstest --watch",
    "ci:lint": "biome ci src",
    "ci:typecheck": "tsc --noEmit",
    "update:packageManager": "corepack use pnpm@latest"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-redux": "^9.3.0",
    "react-vega": "^8.0.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "vega-typings": "^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rsbuild/core": "^2.0.11",
    "@rsbuild/plugin-react": "^2.0.1",
    "@rstest/adapter-rsbuild": "^0.10.3",
    "@rstest/core": "^0.10.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions"
    ],
    "development": [
      "last 1 Chrome version",
      "last 1 Firefox version",
      "last 1 Safari version"
    ]
  }
}
